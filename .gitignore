# Laravel vendor directories (install with: composer install)
services/*/vendor/
services/*/node_modules/
services/*/.git/

# Laravel generated files
services/*/storage/logs/*.log
services/*/storage/framework/cache/
services/*/storage/framework/sessions/
services/*/storage/framework/views/
services/*/bootstrap/cache/*.php

# Environment files (keep .env.example, not .env)
services/*/.env

# SQLite databases
services/*/database/database.sqlite

# Build artifacts
services/*/public/hot
services/*/public/storage
services/*/.phpunit.result.cache
