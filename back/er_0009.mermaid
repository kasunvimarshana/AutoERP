graph TD
    subgraph "Updated Full ERP Blueprint"
        direction LR
        Core[Core & Tenancy] --> Party[Party Master]
        Core --> Product[Product & UoM]
        Product --> Inventory[Inventory & Ledger]
        Inventory --> Procurement[Purchases & Returns]
        Inventory --> Sales[Sales & Returns]
        Procurement --> Accounting[Double-Entry Accounting]
        Sales --> Accounting
        Procurement --> Finance[Payments & Banking]
        Sales --> Finance
        Inventory --> Trace[Traceability Logs]
        Accounting --> Finance
    end
    style Core fill:#e1f5fe
    style Accounting fill:#fff3e0
    style Finance fill:#e8f5e9