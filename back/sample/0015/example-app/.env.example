APP_NAME="Laravel DDD Architect Example"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# DDD Structure preset — change to switch the entire directory layout
# Supported: ddd-layered, ddd-modular, ddd-hexagonal, custom
DDD_STRUCTURE=ddd-layered

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=:memory:

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log
