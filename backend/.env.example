APP_NAME="Inventory Management System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_VERSION=1.0.0
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=inventory
DB_USERNAME=root
DB_PASSWORD=

# Redis / Cache
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=predis
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Passport SSO
PASSPORT_PERSONAL_ACCESS_CLIENT_ID=
PASSPORT_PERSONAL_ACCESS_CLIENT_SECRET=

# Multi-Tenant
TENANT_RESOLUTION_STRATEGY=auto
TENANT_HEADER_ID=X-Tenant-ID
TENANT_HEADER_SLUG=X-Tenant-Slug
TENANT_CACHE_TTL=600

# Message Broker (kafka | rabbitmq | null)
BROKER_DRIVER=null

# Kafka (when BROKER_DRIVER=kafka)
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=inventory-service
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# RabbitMQ (when BROKER_DRIVER=rabbitmq)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=inventory_events

# Saga
SAGA_TIMEOUT=30
SAGA_COMPENSATION_RETRIES=3
SAGA_PERSIST=true

# Webhook
APP_WEBHOOK_RECEIVE_SECRET=change-me-in-production

# Mail
MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@inventory.local"
MAIL_FROM_NAME="${APP_NAME}"
