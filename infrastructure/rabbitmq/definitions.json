{
  "_comment": "RabbitMQ broker definitions for LaravelSAGA – imported at startup via load_definitions",

  "rabbit_version": "3.12.0",
  "rabbitmq_version": "3.12.0",
  "product_name": "RabbitMQ",
  "product_version": "3.12.0",

  "_note_users": "Users are NOT defined here to avoid embedding credentials in source control. RABBITMQ_DEFAULT_USER / RABBITMQ_DEFAULT_PASS env vars in docker-compose.yml bootstrap the broker user at first start.",

  "users": [],

  "vhosts": [
    { "name": "/" }
  ],

  "permissions": [],

  "topic_permissions": [],

  "parameters": [],

  "global_parameters": [
    {
      "name": "cluster_name",
      "value": "saga-cluster"
    }
  ],

  "policies": [
    {
      "vhost": "/",
      "name": "ha-all-queues",
      "pattern": "^(order|inventory|payment|notification)\\.",
      "definition": {
        "ha-mode": "all",
        "ha-sync-mode": "automatic",
        "message-ttl": 86400000,
        "dead-letter-exchange": "saga.dead-letter"
      },
      "priority": 0,
      "apply-to": "queues"
    },
    {
      "vhost": "/",
      "name": "dlq-message-ttl",
      "pattern": "^.*\\.dlq$",
      "definition": {
        "message-ttl": 604800000,
        "max-length": 10000
      },
      "priority": 0,
      "apply-to": "queues"
    }
  ],

  "exchanges": [
    {
      "name": "saga.events",
      "vhost": "/",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {
        "alternate-exchange": "saga.dead-letter"
      }
    },
    {
      "name": "saga.commands",
      "vhost": "/",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "saga.dead-letter",
      "vhost": "/",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "saga.retry",
      "vhost": "/",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    }
  ],

  "queues": [
    {
      "name": "order.commands",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "saga.dead-letter",
        "x-dead-letter-routing-key": "order.commands.dlq",
        "x-message-ttl": 86400000,
        "x-max-length": 100000,
        "x-queue-type": "classic"
      }
    },
    {
      "name": "order.commands.dlq",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-message-ttl": 604800000,
        "x-max-length": 10000,
        "x-queue-type": "classic"
      }
    },
    {
