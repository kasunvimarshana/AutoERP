NODE_ENV=development
PORT=8002

# MongoDB connection
MONGO_URI=mongodb://mongodb:27017/inventory_service

# RabbitMQ connection
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_EXCHANGE=product_events
RABBITMQ_QUEUE=inventory_product_events
RABBITMQ_ROUTING_KEYS=product.created,product.updated,product.deleted

# Product Service URL (for cross-service HTTP calls if needed)
PRODUCT_SERVICE_URL=http://product-service:8001

# Retry configuration
RABBITMQ_RECONNECT_DELAY_MS=5000
RABBITMQ_MAX_RETRIES=10
