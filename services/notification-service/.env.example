APP_NAME="KV Notification Service"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8004

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
