APP_NAME="SaaS Notification Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8004

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql_notification
DB_PORT=3306
DB_DATABASE=saas_notifications
DB_USERNAME=notification_user
DB_PASSWORD=notification_secret

CACHE_STORE=redis
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=secret
REDIS_PORT=6379

QUEUE_CONNECTION=rabbitmq
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=saas_vhost
RABBITMQ_LOGIN=admin
RABBITMQ_PASSWORD=secret

MAIL_MAILER=log
MESSAGE_BROKER_DRIVER=rabbitmq
KAFKA_BROKERS=kafka:29092
WEBHOOK_TIMEOUT=10
WEBHOOK_MAX_RETRIES=3
