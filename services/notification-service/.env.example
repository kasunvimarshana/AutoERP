APP_NAME=NotificationService
APP_ENV=local
APP_KEY=base64:GENERATE_ME
APP_DEBUG=true
APP_URL=http://localhost:8004

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=notification_db
DB_USERNAME=root
DB_PASSWORD=secret

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_FROM_ADDRESS=noreply@laravelSAGA.com
MAIL_FROM_NAME="LaravelSAGA"

SMS_PROVIDER=log
NOTIFICATION_COMMANDS_QUEUE=notification.commands
NOTIFICATION_EVENTS_EXCHANGE=saga.events
LOG_CHANNEL=stack
