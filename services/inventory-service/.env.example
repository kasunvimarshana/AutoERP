APP_NAME="SaaS Inventory Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql_inventory
DB_PORT=3306
DB_DATABASE=saas_inventory
DB_USERNAME=inventory_user
DB_PASSWORD=inventory_secret

CACHE_STORE=redis
CACHE_PREFIX=inventory

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=secret
REDIS_PORT=6379

QUEUE_CONNECTION=rabbitmq

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=saas_vhost
RABBITMQ_LOGIN=admin
RABBITMQ_PASSWORD=secret
RABBITMQ_QUEUE=inventory.commands

KAFKA_BROKERS=kafka:29092
MESSAGE_BROKER_DRIVER=rabbitmq
