APP_NAME="KV Inventory Service"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8002

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql-inventory
DB_PORT=3306
DB_DATABASE=inventory_db
DB_USERNAME=inv_user
DB_PASSWORD=inv_pass

CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

AUTH_SERVICE_URL=http://auth-service:9000

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

KAFKA_BROKERS=kafka:9092

MESSAGE_BROKER=rabbitmq
