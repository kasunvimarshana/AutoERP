APP_NAME="Inventory Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL Database
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=inventory_db
DB_USERNAME=inventory_user
DB_PASSWORD=secret
DB_SCHEMA=public

# Tenant Database Config
TENANT_DB_HOST=postgres
TENANT_DB_PORT=5432
TENANT_DB_USERNAME=inventory_user
TENANT_DB_PASSWORD=secret
TENANT_DB_PREFIX=tenant_

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=2
REDIS_CACHE_DB=3

CACHE_DRIVER=redis
QUEUE_CONNECTION=rabbitmq
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Message Broker
BROKER_DRIVER=rabbitmq

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_EXCHANGE=inventory_events
RABBITMQ_EXCHANGE_TYPE=topic
RABBITMQ_QUEUE=inventory_queue
RABBITMQ_DLX_EXCHANGE=inventory_dlx
RABBITMQ_CONNECTION_TIMEOUT=10
RABBITMQ_READ_WRITE_TIMEOUT=60
RABBITMQ_HEARTBEAT=10
RABBITMQ_KEEPALIVE=false
RABBITMQ_MAX_RETRIES=3

# Kafka (alternative broker)
KAFKA_BROKERS=kafka:9092
KAFKA_CONSUMER_GROUP=inventory-service
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISMS=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# JWT Auth (from auth-service)
JWT_SECRET=
JWT_ALGO=HS256
JWT_TTL=60
JWT_PUBLIC_KEY=

# Auth Service
AUTH_SERVICE_URL=http://auth-service:8000
AUTH_SERVICE_VERIFY_TOKEN_PATH=/api/v1/auth/verify

# Service Identity
SERVICE_NAME=inventory-service
SERVICE_VERSION=1.0.0

# Inventory Config
INVENTORY_LOW_STOCK_THRESHOLD=10
INVENTORY_RESERVATION_TTL=3600
INVENTORY_REORDER_STRATEGY=fixed_quantity
INVENTORY_DEFAULT_CURRENCY=USD

# Multi-Tenant
TENANT_HEADER=X-Tenant-ID
TENANT_ISOLATION=database

# CORS
CORS_ALLOWED_ORIGINS=*
