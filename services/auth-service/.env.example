APP_NAME="Auth Service"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://auth-service.local
APP_PORT=8001
APP_TIMEZONE=UTC
APP_LOCALE=en

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database - PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=auth_service
DB_USERNAME=postgres
DB_PASSWORD=secret
DB_SCHEMA=public

# Tenant Database Strategy (schema|database)
TENANT_DB_STRATEGY=schema
TENANT_DB_PREFIX=tenant_

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Cache
CACHE_DRIVER=redis
CACHE_PREFIX=auth_service_
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Queue
QUEUE_CONNECTION=rabbitmq
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_LOGIN=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_QUEUE=auth_service
RABBITMQ_EXCHANGE=saas_exchange

# Mail
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@saas.local"
MAIL_FROM_NAME="${APP_NAME}"

# Passport / OAuth
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=
PASSPORT_PERSONAL_ACCESS_CLIENT_ID=
PASSPORT_PERSONAL_ACCESS_CLIENT_SECRET=
PASSPORT_TOKEN_EXPIRE_DAYS=15
PASSPORT_REFRESH_TOKEN_EXPIRE_DAYS=30
PASSPORT_PERSONAL_ACCESS_TOKEN_EXPIRE_MONTHS=6

# JWT (tymon/jwt-auth)
JWT_SECRET=
JWT_ALGO=HS256
JWT_TTL=60
JWT_REFRESH_TTL=20160
JWT_BLACKLIST_ENABLED=true
JWT_BLACKLIST_GRACE_PERIOD=30

# Tenant Resolution
TENANT_IDENTIFICATION_DRIVER=subdomain
TENANT_SUBDOMAIN_COLUMN=subdomain
TENANT_HEADER=X-Tenant-ID
TENANT_CENTRAL_DOMAINS="localhost,auth-service.local"

# SSO
SSO_ENABLED=true
SSO_SHARED_SECRET=
SSO_TOKEN_LIFETIME=3600

# CORS
CORS_ALLOWED_ORIGINS="*"
CORS_ALLOWED_METHODS="GET,POST,PUT,PATCH,DELETE,OPTIONS"
CORS_ALLOWED_HEADERS="Content-Type,Accept,Authorization,X-Tenant-ID,X-Device-ID,X-Request-ID"

# Security
BCRYPT_ROUNDS=12
PASSWORD_RESET_TIMEOUT=3600
RATE_LIMIT_LOGIN=5
RATE_LIMIT_REGISTER=3
RATE_LIMIT_API=60

# Service Discovery
SERVICE_NAME=auth-service
SERVICE_VERSION=1.0.0
CONSUL_HOST=consul
CONSUL_PORT=8500

# Audit
AUDIT_LOG_ENABLED=true
AUDIT_LOG_CHANNEL=stack

# Feature Flags
FEATURE_MULTI_FACTOR_AUTH=false
FEATURE_DEVICE_TRACKING=true
FEATURE_AUDIT_LOG=true
FEATURE_RBAC=true
FEATURE_ABAC=true
