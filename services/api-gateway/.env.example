APP_NAME="SaaS API Gateway"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql_gateway
DB_PORT=3306
DB_DATABASE=saas_gateway
DB_USERNAME=gateway_user
DB_PASSWORD=gateway_secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=rabbitmq

CACHE_STORE=redis
CACHE_PREFIX=gateway

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=secret
REDIS_PORT=6379
REDIS_DB=0

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@saas.local"
MAIL_FROM_NAME="${APP_NAME}"

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=saas_vhost
RABBITMQ_LOGIN=admin
RABBITMQ_PASSWORD=secret
RABBITMQ_QUEUE=gateway.commands

KAFKA_BROKERS=kafka:29092

# Service URLs
INVENTORY_SERVICE_URL=http://inventory_service
ORDER_SERVICE_URL=http://order_service
PAYMENT_SERVICE_URL=http://payment_service:3000
NOTIFICATION_SERVICE_URL=http://notification_service
SAGA_ORCHESTRATOR_URL=http://saga_orchestrator

# Passport
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=

# Message Broker Driver
MESSAGE_BROKER_DRIVER=rabbitmq
