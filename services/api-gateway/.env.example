APP_NAME="LaravelSAGA API Gateway"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000
APP_DOMAIN=localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=api-gateway-db
DB_PORT=3306
DB_DATABASE=api_gateway
DB_USERNAME=saga_user
DB_PASSWORD=

# ---------------------------------------------------------------------------
# Cache / Session / Queue
# ---------------------------------------------------------------------------
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=api-gateway-redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Mail
# ---------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Laravel Passport
# ---------------------------------------------------------------------------
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=
PASSPORT_PERSONAL_ACCESS_CLIENT_ID=
PASSPORT_PERSONAL_ACCESS_CLIENT_SECRET=
PASSPORT_TOKEN_EXPIRE_DAYS=7
PASSPORT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------------------------------------------------------------------------
# Upstream microservices
# ---------------------------------------------------------------------------
ORDER_SERVICE_URL=http://order-service:8001
ORDER_SERVICE_TIMEOUT=10

INVENTORY_SERVICE_URL=http://inventory-service:8002
INVENTORY_SERVICE_TIMEOUT=10

PAYMENT_SERVICE_URL=http://payment-service:8003
PAYMENT_SERVICE_TIMEOUT=15

NOTIFICATION_SERVICE_URL=http://notification-service:8004
NOTIFICATION_SERVICE_TIMEOUT=5

# ---------------------------------------------------------------------------
# RabbitMQ
# ---------------------------------------------------------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
