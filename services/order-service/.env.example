# Application
APP_NAME="Order Service"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8003

# Logging
LOG_CHANNEL=stderr
LOG_LEVEL=info

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=order_service
DB_USERNAME=laravel
DB_PASSWORD=secret

# Cache / Session / Queue
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# RabbitMQ
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=order.events
RABBITMQ_EXCHANGE_TYPE=topic
RABBITMQ_QUEUE=order-events
RABBITMQ_DURABLE=true
RABBITMQ_HEARTBEAT=60
RABBITMQ_CONNECTION_TIMEOUT=3.0
RABBITMQ_READ_WRITE_TIMEOUT=3.0

# Keycloak
KEYCLOAK_BASE_URL=http://keycloak:8080
KEYCLOAK_REALM=inventory
KEYCLOAK_CLIENT_ID=order-service
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_JWKS_CACHE_TTL=3600

# Downstream Services
INVENTORY_SERVICE_URL=http://inventory-service:9000
INVENTORY_SERVICE_TIMEOUT=5
INVENTORY_SERVICE_RETRY_TIMES=3
INVENTORY_SERVICE_RETRY_SLEEP=500
