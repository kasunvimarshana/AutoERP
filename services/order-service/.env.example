APP_NAME="KV Order Service"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8003

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql-order
DB_PORT=3306
DB_DATABASE=order_db
DB_USERNAME=order_user
DB_PASSWORD=order_pass

CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

AUTH_SERVICE_URL=http://auth-service:9000
INVENTORY_SERVICE_URL=http://inventory-service:9000
SAGA_ORCHESTRATOR_URL=http://saga-orchestrator:9000

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

KAFKA_BROKERS=kafka:9092
MESSAGE_BROKER=rabbitmq
