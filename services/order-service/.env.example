APP_NAME="SAGA Order Service"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8001

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Database – MySQL
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=orders_db
DB_USERNAME=orders_user
DB_PASSWORD=orders_password

# ---------------------------------------------------------------------------
# Cache / Session / Queue
# ---------------------------------------------------------------------------
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ---------------------------------------------------------------------------
# Redis – Saga state store
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PASSWORD=redis_password
REDIS_PORT=6379

# Redis key prefix to avoid collisions with other services.
REDIS_PREFIX=order_service:

# ---------------------------------------------------------------------------
# RabbitMQ – Message bus
# ---------------------------------------------------------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=saga_user
RABBITMQ_PASSWORD=saga_password
RABBITMQ_VHOST=/
RABBITMQ_REPLIES_QUEUE=saga.orchestrator.replies

# ---------------------------------------------------------------------------
# Saga Orchestrator settings
# ---------------------------------------------------------------------------
SAGA_ORCHESTRATOR_ENABLED=true
SAGA_TIMEOUT_SECONDS=30
SAGA_STATE_TTL_SECONDS=86400

# ---------------------------------------------------------------------------
# Downstream service URLs (used for health checks / direct calls if needed)
# ---------------------------------------------------------------------------
INVENTORY_SERVICE_URL=http://inventory-service:8002
PAYMENT_SERVICE_URL=http://payment-service:8003
NOTIFICATION_SERVICE_URL=http://notification-service:8004

# ---------------------------------------------------------------------------
# Mail (log driver for local dev)
# ---------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS="orders@laravelsaga.local"
MAIL_FROM_NAME="${APP_NAME}"
