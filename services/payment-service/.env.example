NODE_ENV=local
PORT=3000
SERVICE_NAME=payment-service
DB_HOST=mysql_payment
DB_PORT=3306
DB_DATABASE=saas_payments
DB_USER=payment_user
DB_PASSWORD=payment_secret
DB_POOL_MAX=10
DB_POOL_MIN=2
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=secret
RABBITMQ_URL=amqp://admin:secret@rabbitmq/saas_vhost
RABBITMQ_EXCHANGE=payment.events
KAFKA_BROKERS=kafka:29092
MESSAGE_BROKER_DRIVER=rabbitmq
LOG_LEVEL=info
