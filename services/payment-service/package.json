{
  "name": "payment-service",
  "version": "1.0.0",
  "description": "Payment microservice for LaravelSAGA — Node.js/MongoDB/RabbitMQ",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --runInBand --forceExit --coverage"
  },
  "dependencies": {
    "amqplib": "^0.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "joi": "^17.0.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.0.0",
    "uuid": "^9.0.0",
    "winston": "^3.0.0"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "mongodb-memory-server": "^9.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
