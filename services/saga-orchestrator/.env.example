APP_NAME="KV Saga Orchestrator"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8005

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql-order
DB_PORT=3306
DB_DATABASE=order_db
DB_USERNAME=order_user
DB_PASSWORD=order_pass

CACHE_DRIVER=redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

KAFKA_BROKERS=kafka:9092
MESSAGE_BROKER=rabbitmq

INVENTORY_SERVICE_URL=http://inventory-service:9000
ORDER_SERVICE_URL=http://order-service:9000
NOTIFICATION_SERVICE_URL=http://notification-service:9000
