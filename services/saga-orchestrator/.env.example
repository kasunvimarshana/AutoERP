APP_NAME="SaaS Saga Orchestrator"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8005

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql_saga
DB_PORT=3306
DB_DATABASE=saas_saga
DB_USERNAME=saga_user
DB_PASSWORD=saga_secret

CACHE_STORE=redis
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=secret
REDIS_PORT=6379

QUEUE_CONNECTION=rabbitmq
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=saas_vhost
RABBITMQ_LOGIN=admin
RABBITMQ_PASSWORD=secret

KAFKA_BROKERS=kafka:29092
MESSAGE_BROKER_DRIVER=rabbitmq

# Service URLs
INVENTORY_SERVICE_URL=http://inventory_service
ORDER_SERVICE_URL=http://order_service
PAYMENT_SERVICE_URL=http://payment_service:3000
NOTIFICATION_SERVICE_URL=http://notification_service

# Saga Timeouts (seconds)
SAGA_STEP_TIMEOUT=30
SAGA_MAX_RETRIES=3
