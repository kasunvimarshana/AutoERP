# ─── Order Service ───────────────────────────────────────────────────────────
ORDER_APP_KEY=base64:your_order_app_key_here
ORDER_DB_HOST=mysql
ORDER_DB_PORT=3306
ORDER_DB_DATABASE=orders_db
ORDER_DB_USERNAME=orders_user
ORDER_DB_PASSWORD=orders_password

# ─── Inventory Service ───────────────────────────────────────────────────────
INVENTORY_APP_KEY=base64:your_inventory_app_key_here
INVENTORY_DB_HOST=postgres
INVENTORY_DB_PORT=5432
INVENTORY_DB_DATABASE=inventory_db
INVENTORY_DB_USERNAME=inventory_user
INVENTORY_DB_PASSWORD=inventory_password

# ─── Payment Service ─────────────────────────────────────────────────────────
PAYMENT_PORT=8002
PAYMENT_GIN_MODE=release

# ─── Notification Service ────────────────────────────────────────────────────
NOTIFICATION_PORT=8003
MONGODB_URI=mongodb://mongo:27017/notifications_db
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# ─── Shared Infrastructure ───────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_MANAGEMENT_PORT=15672

# ─── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=orders_db
MYSQL_USER=orders_user
MYSQL_PASSWORD=orders_password

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=inventory_db
POSTGRES_USER=inventory_user
POSTGRES_PASSWORD=inventory_password

# ─── Saga Configuration ───────────────────────────────────────────────────────
SAGA_TIMEOUT=300
