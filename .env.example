# =============================================================================
# Enterprise Inventory Management System — Environment Configuration
# Copy this file to .env and fill in your values before starting services.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Database (MySQL)
# ---------------------------------------------------------------------------
DB_ROOT_PASSWORD=rootsecret
DB_DATABASE=inventory
DB_USERNAME=inventory_user
DB_PASSWORD=inventory_pass

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Message Broker
# Choose: rabbitmq | kafka
# ---------------------------------------------------------------------------
MESSAGE_BROKER_DRIVER=rabbitmq

RABBITMQ_USER=admin
RABBITMQ_PASS=rabbitsecret
RABBITMQ_VHOST=inventory

# Kafka (used if MESSAGE_BROKER_DRIVER=kafka)
KAFKA_BROKERS=kafka:9092

# ---------------------------------------------------------------------------
# Laravel Passport (SSO)
# Generate with: php artisan passport:keys
# ---------------------------------------------------------------------------
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api/v1
