# ==============================================================================
# Enterprise Multi-Tenant SaaS Inventory Management System
# Environment Configuration Template
# ==============================================================================

# Application Environment
APP_ENV=local
APP_DEBUG=true

# API Gateway Keys
GATEWAY_APP_KEY=base64:your-gateway-key-here
INVENTORY_APP_KEY=base64:your-inventory-key-here
ORDER_APP_KEY=base64:your-order-key-here
NOTIFICATION_APP_KEY=base64:your-notification-key-here
SAGA_APP_KEY=base64:your-saga-key-here

# Database Root
MYSQL_ROOT_PASSWORD=rootsecret

# Gateway Database
GATEWAY_DB_NAME=saas_gateway
GATEWAY_DB_USER=gateway_user
GATEWAY_DB_PASSWORD=gateway_secret

# Inventory Database
INVENTORY_DB_NAME=saas_inventory
INVENTORY_DB_USER=inventory_user
INVENTORY_DB_PASSWORD=inventory_secret

# Order Database
ORDER_DB_NAME=saas_orders
ORDER_DB_USER=order_user
ORDER_DB_PASSWORD=order_secret

# Payment Database
PAYMENT_DB_NAME=saas_payments
PAYMENT_DB_USER=payment_user
PAYMENT_DB_PASSWORD=payment_secret

# Notification Database
NOTIFICATION_DB_NAME=saas_notifications
NOTIFICATION_DB_USER=notification_user
NOTIFICATION_DB_PASSWORD=notification_secret

# Saga Database
SAGA_DB_NAME=saas_saga
SAGA_DB_USER=saga_user
SAGA_DB_PASSWORD=saga_secret

# Redis
REDIS_PASSWORD=secret

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASS=secret
RABBITMQ_VHOST=saas_vhost

# Message Broker Driver (rabbitmq|kafka)
MESSAGE_BROKER_DRIVER=rabbitmq

# Kafka
KAFKA_BROKERS=localhost:9092
