APP_NAME="KV_SSO Auth Service"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kv_sso
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=redis
CACHE_PREFIX=kv_sso

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

PASSPORT_PRIVATE_KEY_PATH=storage/passport/private.key
PASSPORT_PUBLIC_KEY_PATH=storage/passport/public.key

HORIZON_MEMORY_LIMIT=64
TELESCOPE_ENABLED=false

# Password Hashing (argon2id recommended)
HASHING_DRIVER=argon2id
ARGON_MEMORY=65536
ARGON_TIME=4
ARGON_THREADS=1

# SSO Token Lifetimes (minutes / days)
SSO_ACCESS_TOKEN_TTL_MINUTES=15
SSO_REFRESH_TOKEN_TTL_DAYS=30
SSO_PERSONAL_ACCESS_TOKEN_TTL_MONTHS=6
SSO_SERVICE_TOKEN_TTL_MINUTES=60

# SSO Security Settings
SSO_MAX_FAILED_ATTEMPTS=10
SSO_LOCKOUT_SECONDS=900
SSO_REQUIRE_2FA=false
SSO_SESSION_BINDING=true

# SSO Rate Limiting
SSO_RATE_AUTH_PER_MINUTE=10
SSO_RATE_API_PER_MINUTE=60
SSO_RATE_SERVICE_PER_MINUTE=600

# Service-to-Service Auth
SSO_SERVICE_AUTH_ENABLED=true
SSO_SERVICE_ISSUER="${APP_URL}"
SSO_SERVICE_AUDIENCE=kv-sso-microservices

# Feature Flags & Tenant Config Cache TTL (seconds)
SSO_FEATURE_FLAG_CACHE_TTL=300
SSO_PUBLIC_KEY_CACHE_TTL=3600
