# ─────────────────────────────────────────────────────────────────────────────
# KV-SAAS — Environment Variables
# Copy this file to .env and fill in actual values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

APP_ENV=production

# ─── Nginx ────────────────────────────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ─── Auth Service ─────────────────────────────────────────────────────────────
AUTH_APP_KEY=base64:CHANGE_ME_AUTH
AUTH_APP_URL=http://localhost:8001
AUTH_DB_DATABASE=auth_db
AUTH_DB_USERNAME=auth_user
AUTH_DB_PASSWORD=CHANGE_ME
AUTH_DB_ROOT_PASSWORD=CHANGE_ME_ROOT
PASSPORT_PERSONAL_ACCESS_CLIENT_ID=1
PASSPORT_PERSONAL_ACCESS_CLIENT_SECRET=CHANGE_ME

# ─── User Service ─────────────────────────────────────────────────────────────
USER_APP_KEY=base64:CHANGE_ME_USER
USER_APP_URL=http://localhost:8002
USER_DB_DATABASE=user_db
USER_DB_USERNAME=user_db_user
USER_DB_PASSWORD=CHANGE_ME
USER_DB_ROOT_PASSWORD=CHANGE_ME_ROOT

# ─── Product Service ──────────────────────────────────────────────────────────
PRODUCT_APP_KEY=base64:CHANGE_ME_PRODUCT
PRODUCT_APP_URL=http://localhost:8003
PRODUCT_DB_DATABASE=product_db
PRODUCT_DB_USERNAME=product_db_user
PRODUCT_DB_PASSWORD=CHANGE_ME
PRODUCT_DB_ROOT_PASSWORD=CHANGE_ME_ROOT

# ─── Inventory Service ────────────────────────────────────────────────────────
INVENTORY_APP_KEY=base64:CHANGE_ME_INVENTORY
INVENTORY_APP_URL=http://localhost:8004
INVENTORY_DB_DATABASE=inventory_db
INVENTORY_DB_USERNAME=inventory_db_user
INVENTORY_DB_PASSWORD=CHANGE_ME
INVENTORY_DB_ROOT_PASSWORD=CHANGE_ME_ROOT

# ─── Order Service ────────────────────────────────────────────────────────────
ORDER_APP_KEY=base64:CHANGE_ME_ORDER
ORDER_APP_URL=http://localhost:8005
ORDER_DB_DATABASE=order_db
ORDER_DB_USERNAME=order_db_user
ORDER_DB_PASSWORD=CHANGE_ME
ORDER_DB_ROOT_PASSWORD=CHANGE_ME_ROOT

# ─── Service Discovery (internal URLs) ───────────────────────────────────────
AUTH_SERVICE_URL=http://auth-service:8001
USER_SERVICE_URL=http://user-service:8002
PRODUCT_SERVICE_URL=http://product-service:8003
INVENTORY_SERVICE_URL=http://inventory-service:8004

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS
REDIS_PORT=6379
REDIS_MAXMEMORY=256mb

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=kvsaas_admin
RABBITMQ_PASSWORD=CHANGE_ME_RABBIT
RABBITMQ_VHOST=kvsaas
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
